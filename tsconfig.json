{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "outDir": "dist",
    "baseUrl": "src",
    "rootDir": "src",
    "allowJs": true,
    "checkJs": false
  },
  "include": ["src/**/*", "vite.config.mts"],
  "exclude": [
    "node_modules", "dist",
    "vite.config.mts"
  ]
}